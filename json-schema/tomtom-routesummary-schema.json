{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/RouteSummary",
  "title": "RouteSummary",
  "type": "object",
  "properties": {
    "lengthInMeters": {
      "type": "integer"
    },
    "travelTimeInSeconds": {
      "type": "integer"
    },
    "trafficDelayInSeconds": {
      "type": "integer"
    },
    "trafficLengthInMeters": {
      "type": "integer"
    },
    "departureTime": {
      "type": "string",
      "format": "date-time"
    },
    "arrivalTime": {
      "type": "string",
      "format": "date-time"
    },
    "noTrafficTravelTimeInSeconds": {
      "type": "integer"
    },
    "historicTrafficTravelTimeInSeconds": {
      "type": "integer"
    },
    "liveTrafficIncidentsTravelTimeInSeconds": {
      "type": "integer"
    }
  }
}